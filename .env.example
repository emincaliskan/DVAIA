# DVAIA - Environment Configuration Example
# Copy this file to .env and fill in values.

# ============================================================
# LLM backend: Anthropic Claude (REQUIRED)
# ============================================================

# Your Anthropic API key -- get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Default LLM model for chat panels (default: claude-sonnet-4-6)
#DEFAULT_MODEL=claude-sonnet-4-6

# Agentic panel: model for CoT + tool use (default: claude-sonnet-4-6).
# Claude Sonnet 4.6 and Opus 4.7 both support extended thinking.
#AGENTIC_MODEL=claude-sonnet-4-6

# ============================================================
# App configuration
# ============================================================

# Flask server port (default: 5000)
#PORT=5000

# Flask SECRET_KEY for sessions. Generate with: openssl rand -hex 32
# MUST be set in production so sessions survive redeploys.
#SECRET_KEY=change-me

# ============================================================
# Basic-auth gate for the deployed app (STRONGLY RECOMMENDED)
# ============================================================
# When both are set, every HTTP request requires these credentials
# (except /api/health, so Render health checks keep working).
# Leave unset for unauthenticated local development.

#DVAIA_BASIC_AUTH_USER=dvaia
#DVAIA_BASIC_AUTH_PASSWORD=change-this-long-shared-password

# ============================================================
# Storage paths
# ============================================================

# SQLite DB (default: <project>/data/app.db)
#DATABASE_URI=/var/data/app.db

# Uploaded files (default: <project>/data/uploads)
#UPLOAD_DIR=/var/data/uploads

# Payload generation output (default: <project>/payloads/generate)
#PAYLOADS_OUTPUT_DIR=/var/data/payloads

# ============================================================
# RAG: embedded Qdrant (default) or remote server
# ============================================================
# By default Qdrant runs embedded and stores to QDRANT_LOCAL_PATH.
# On Render attach a persistent disk and point this at its mount path.

#QDRANT_LOCAL_PATH=/var/data/qdrant

# Or point to a remote Qdrant (e.g. Qdrant Cloud):
#QDRANT_URL=https://your-cluster.qdrant.tech
#QDRANT_API_KEY=...
#QDRANT_COLLECTION=rag_chunks

# Embedding backend / model (defaults: fastembed / BAAI/bge-small-en-v1.5)
#EMBEDDING_BACKEND=fastembed
#EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
